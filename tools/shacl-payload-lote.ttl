@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix pig:  <https://espordata.eu/vocab/pig#> .
@prefix porkv: <https://pork-dataspace.eu/shapes/payload/> .

# ─────────────────────────────────────────────────────────
#  VALIDADOR SHACL — Payload de Lote Porcino
#  Deriva de: https://espordata.eu/vocab/pig (dataset-tipo-lote.ttl)
#  Valida instancias de pig:Batch en los datos del proveedor.
#  Ejecutar con pySHACL contra el payload real del dataset.
# ─────────────────────────────────────────────────────────

porkv:BatchShape
    a sh:NodeShape ;
    sh:targetClass pig:Batch ;
    sh:name    "Validador payload — lote porcino"@es ;

    # ── OBLIGATORIOS ──────────────────────────────────────

    # Identificador único global: exactamente 1
    sh:property [
        sh:path     pig:batchId ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:severity sh:Violation ;
        sh:message  "Cada lote debe tener exactamente un pig:batchId no vacío."@es ;
    ] ;

    # Explotación de origen: obligatoria
    sh:property [
        sh:path     pig:farm ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Violation ;
        sh:message  "El lote debe referenciar exactamente una pig:Farm."@es ;
    ] ;

    # Fecha de entrada: obligatoria
    sh:property [
        sh:path     pig:entryDate ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:severity sh:Violation ;
        sh:message  "El lote debe tener pig:entryDate (fecha de entrada al ciclo)."@es ;
    ] ;

    # Número de animales en entrada: obligatorio y positivo
    sh:property [
        sh:path         pig:numberOfAnimalsIn ;
        sh:minCount     1 ;
        sh:maxCount     1 ;
        sh:datatype     xsd:integer ;
        sh:minInclusive 1 ;
        sh:severity     sh:Violation ;
        sh:message      "pig:numberOfAnimalsIn debe ser un entero mayor que 0."@es ;
    ] ;

    # ── RECOMENDADOS ──────────────────────────────────────

    # Código local de granja
    sh:property [
        sh:path     pig:batchLocalCode ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:minLength 1 ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar pig:batchLocalCode."@es ;
    ] ;

    # Fecha de nacimiento / entrada a primera nave
    sh:property [
        sh:path     pig:birthDate ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar pig:birthDate."@es ;
    ] ;

    # Fecha de salida
    sh:property [
        sh:path     pig:exitDate ;
        sh:maxCount 1 ;
        sh:datatype xsd:date ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar pig:exitDate."@es ;
    ] ;

    # Peso total del lote (kg, positivo)
    sh:property [
        sh:path          pig:totalWeight ;
        sh:maxCount      1 ;
        sh:datatype      xsd:decimal ;
        sh:minExclusive  0 ;
        sh:severity      sh:Warning ;
        sh:message       "pig:totalWeight debe ser un decimal mayor que 0 (kg)."@es ;
    ] ;

    # Peso medio (kg, positivo)
    sh:property [
        sh:path          pig:averageWeight ;
        sh:maxCount      1 ;
        sh:datatype      xsd:decimal ;
        sh:minExclusive  0 ;
        sh:severity      sh:Warning ;
        sh:message       "pig:averageWeight debe ser un decimal mayor que 0 (kg)."@es ;
    ] ;

    # Raza o línea genética
    sh:property [
        sh:path     pig:breed ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:class    skos:Concept ;
        sh:severity sh:Warning ;
        sh:message  "pig:breed debe ser una IRI que apunte a un skos:Concept del pig:BreedScheme."@es ;
    ] ;

    # Código de nave o corral
    sh:property [
        sh:path     pig:buildingCode ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar pig:buildingCode."@es ;
    ] ;

    # ── OPCIONALES ────────────────────────────────────────

    # Referencia a documentación externa (URI)
    sh:property [
        sh:path     pig:documentation ;
        sh:datatype xsd:anyURI ;
        sh:severity sh:Info ;
    ] ;

    # Observaciones libres
    sh:property [
        sh:path     pig:note ;
        sh:datatype xsd:string ;
        sh:severity sh:Info ;
    ] ;

    # ── RESTRICCIONES CRUZADAS ────────────────────────────

    # Si exitDate existe, debe ser posterior o igual a entryDate
    sh:sparql [
        sh:message  "pig:exitDate no puede ser anterior a pig:entryDate."@es ;
        sh:severity sh:Violation ;
        sh:prefixes pig: ;
        sh:select   """
            SELECT $this ?entryDate ?exitDate
            WHERE {
                $this pig:entryDate ?entryDate .
                $this pig:exitDate  ?exitDate .
                FILTER (?exitDate < ?entryDate)
            }
        """ ;
    ] ;

    # Si birthDate existe, debe ser anterior o igual a entryDate
    sh:sparql [
        sh:message  "pig:birthDate no puede ser posterior a pig:entryDate."@es ;
        sh:severity sh:Violation ;
        sh:prefixes pig: ;
        sh:select   """
            SELECT $this ?birthDate ?entryDate
            WHERE {
                $this pig:birthDate ?birthDate .
                $this pig:entryDate ?entryDate .
                FILTER (?birthDate > ?entryDate)
            }
        """ ;
    ] ;

    # totalWeight debe ser coherente con averageWeight * numberOfAnimalsIn (±10%)
    sh:sparql [
        sh:message  "pig:totalWeight difiere más de un 10% de averageWeight × numberOfAnimalsIn."@es ;
        sh:severity sh:Warning ;
        sh:prefixes pig: ;
        sh:select   """
            SELECT $this ?totalWeight ?expected
            WHERE {
                $this pig:totalWeight       ?totalWeight .
                $this pig:averageWeight     ?avgW .
                $this pig:numberOfAnimalsIn ?n .
                BIND (?avgW * ?n AS ?expected)
                FILTER (ABS(?totalWeight - ?expected) > ?expected * 0.1)
            }
        """ ;
    ] .

# ─────────────────────────────────────────────────────────
#  Shape auxiliar: Farm (validación mínima del nodo referenciado)
# ─────────────────────────────────────────────────────────

porkv:FarmShape
    a sh:NodeShape ;
    sh:targetClass pig:Farm ;

    sh:property [
        sh:path     pig:batchId ;
        sh:severity sh:Info ;
    ] .