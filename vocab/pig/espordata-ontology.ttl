@prefix : <https://espordata.es/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@base <https://espordata.es/ontology/> .

#################################################################
# ESPORDATA ONTOLOGY
# Unified 4-layer ontology for the Spanish porcine data space
#
# Layer 1 - Functional Business Domains (SKOS)
# Layer 2 - Core Domain Model (OWL)
# Layer 3 - Properties Model (OWL + skos:notation)
# Layer 4 - Controlled Vocabularies (SKOS)
#################################################################

<https://espordata.es/ontology/> rdf:type owl:Ontology ;
    owl:imports <http://www.w3.org/2004/02/skos/core> ;
    dct:title "ESPORDATA Ontology"@en ,
              "Ontología ESPORDATA"@es ;
    dct:description "Ontología unificada del espacio de datos ESPORDATA para el sector porcino español. Modela los dominios funcionales de negocio, las clases de dominio (animal, lote, sanidad, alimentación, reproducción, controles), sus propiedades y los vocabularios controlados alineados con los catálogos oficiales SITRAN/SIEX/FEGA."@es ;
    dct:creator [ foaf:name "Jose Manuel García de la Cuadra Nacher" ;
                  foaf:mbox <mailto:jgarcia@hiberus.com> ] ;
    dct:publisher [ foaf:name "Hiberus / ESPORDATA" ;
                    foaf:homepage <https://espordata.es/> ] ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:issued "2025-01-15"^^xsd:date ;
    dct:modified "2026-05-07"^^xsd:date ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <https://espordata.es/ontology/1.0.0/> ;
    vann:preferredNamespacePrefix "esp" ;
    vann:preferredNamespaceUri "https://espordata.es/ontology/" ;
    rdfs:seeAlso <https://www3.sede.fega.gob.es/bdcsixpor/catalogos> ,
                 <https://servicio.mapa.gob.es/regega/> .


#################################################################
# Annotation properties
#################################################################

skos:definition     rdf:type owl:AnnotationProperty .
skos:inScheme       rdf:type owl:AnnotationProperty .
skos:notation       rdf:type owl:AnnotationProperty .
skos:prefLabel      rdf:type owl:AnnotationProperty .
skos:topConceptOf   rdf:type owl:AnnotationProperty .
skos:broader        rdf:type owl:AnnotationProperty .
skos:related        rdf:type owl:AnnotationProperty .


#################################################################
#################################################################
##                                                             ##
##  LAYER 1 - FUNCTIONAL BUSINESS DOMAINS (SKOS)               ##
##                                                             ##
#################################################################
#################################################################

:EspordataBusinessDomains rdf:type skos:ConceptScheme ;
    skos:prefLabel "Espordata Functional Business Domains"@en ;
    skos:prefLabel "Dominios Funcionales de Negocio Espordata"@es ;
    rdfs:comment "Taxonomía funcional de dominios de negocio del espacio de datos Espordata."@es .

:DP0001 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0001" ;
    skos:prefLabel "Producción animal"@es , "Animal Production"@en ;
    skos:definition "Dominio que engloba los datos relativos al ciclo productivo de los animales, incluyendo rendimientos, crecimientos y parámetros de seguimiento de la producción en granja."@es .

:DP0002 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0002" ;
    skos:prefLabel "Sanidad Animal"@es , "Animal Health"@en ;
    skos:definition "Dominio que recoge la información sobre el estado sanitario de los animales, tratamientos veterinarios, incidencias y protocolos de prevención y control de enfermedades."@es .

:DP0003 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0003" ;
    skos:prefLabel "Alimentación"@es , "Animal Feeding"@en ;
    skos:definition "Dominio que gestiona los datos relacionados con la nutrición animal, incluyendo composición de piensos, planes de alimentación y consumos por lote o explotación."@es .

:DP0004 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0004" ;
    skos:prefLabel "Trazabilidad y Movimientos"@es , "Traceability and Animal Movements"@en ;
    skos:definition "Dominio que centraliza la información sobre el seguimiento y localización de los animales a lo largo de toda la cadena, registrando entradas, salidas y traslados entre instalaciones."@es .

:DP0005 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0005" ;
    skos:prefLabel "Explotación / Infraestructura"@es , "Farm Infrastructure"@en ;
    skos:definition "Dominio que recoge los datos descriptivos y operativos de las instalaciones productivas, incluyendo características físicas, capacidades y equipamiento disponible."@es .

:DP0006 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0006" ;
    skos:prefLabel "Bienestar Animal"@es , "Animal Welfare"@en ;
    skos:definition "Dominio que documenta los indicadores y registros relacionados con las condiciones de vida de los animales, velando por el cumplimiento de los estándares de bienestar establecidos."@es .

:DP0007 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0007" ;
    skos:prefLabel "Producción Agregada y KPIs"@es , "Aggregated Production and KPIs"@en ;
    skos:definition "Dominio que consolida los datos de producción a nivel agregado, proporcionando los indicadores clave de rendimiento necesarios para la toma de decisiones estratégicas."@es .

:DP0008 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0008" ;
    skos:prefLabel "Matadero y Procesado"@es , "Slaughterhouse and Processing"@en ;
    skos:definition "Dominio que gestiona la información relativa a los procesos de sacrificio, faenado y transformación del producto, incluyendo rendimientos de canal y control de calidad en planta."@es .

:DP0009 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0009" ;
    skos:prefLabel "Comercialización"@es , "Commercialization"@en ;
    skos:definition "Dominio que recoge los datos vinculados a la venta y distribución del producto, incluyendo precios, clientes, contratos y condiciones comerciales."@es .

:DP0010 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0010" ;
    skos:prefLabel "Medio Ambiente y Sostenibilidad"@es , "Environment and Sustainability"@en ;
    skos:definition "Dominio que centraliza los datos relacionados con el impacto ambiental de la actividad productiva, incluyendo emisiones, gestión de residuos y métricas de sostenibilidad."@es .

:DP0011 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0011" ;
    skos:prefLabel "Cumplimiento Normativo"@es , "Regulatory Compliance"@en ;
    skos:definition "Dominio que agrupa la información necesaria para acreditar el cumplimiento de la legislación vigente aplicable a la actividad, incluyendo registros, certificaciones y auditorías."@es .

:DP0012 rdf:type skos:Concept ;
    skos:inScheme :EspordataBusinessDomains ;
    skos:notation "DP0012" ;
    skos:prefLabel "Bioseguridad"@es , "Biosecurity"@en ;
    skos:definition "Dominio que documenta los protocolos, medidas y registros orientados a prevenir la entrada y propagación de agentes patógenos en las instalaciones productivas."@es .


#################################################################
#################################################################
##                                                             ##
##  LAYER 2 - CORE DOMAIN MODEL (OWL)                          ##
##                                                             ##
##  Classes with owl:Restriction + qualifiedCardinality        ##
##  Following the Agrixels pattern (mandatory vs optional)     ##
##                                                             ##
#################################################################
#################################################################

#################################################################
# ANIMAL PRODUCTION DOMAIN - DP0001
#################################################################

:Animal rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :animalIdentifier ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :birthDate ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:date
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :animalAge ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :animalWeight ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:decimal
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :belongsToBatch ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass :Batch
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasSpecies ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :animalBreed ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :animalSex ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Animales porcinos"@es , "Pigs"@en ;
    rdfs:comment "Conjunto de cerdos que forman parte del sistema productivo porcino, clasificados según su edad, sexo y especie."@es ;
    dct:subject :DP0001 .

:Batch rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :batchIdentifier ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:string
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :numberOfAnimals ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:integer
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :batchEntryDate ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:date
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :slaughterDate ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:date
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :totalWeight ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:decimal
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :averageWeight ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:decimal
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :batchBreed ;
          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :belongsToFarm ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Lotes"@es , "Batches"@en ;
    rdfs:comment "Conjunto de cerdos que se agrupan dentro de una explotación porcina."@es ;
    dct:subject :DP0001 .

:PorcineReproduction rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :reproductiveSex ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasReproductionMethod ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasReproductiveStatus ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasReproductionResult ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Reproducción porcina"@es , "Porcine Reproduction"@en ;
    rdfs:comment "Proceso biológico y manejo técnico mediante el cual se obtienen nuevas crías en la granja porcina, incluyendo actividades como la monta o inseminación, gestación, parto y lactancia."@es ;
    dct:subject :DP0001 .


#################################################################
# ANIMAL HEALTH DOMAIN - DP0002
#################################################################

:ControlPoint rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasControlType ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :controlFrequency ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :controlResponsible ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :controlStatus ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Puntos de control porcino"@es , "Control Points"@en ;
    rdfs:comment "Procesos específicos dentro de la explotación porcina donde se realizan mediciones, inspecciones o registros sistemáticos con el fin de monitorear, evaluar y asegurar el correcto funcionamiento de la producción."@es ;
    dct:subject :DP0002 .

:VeterinaryTreatment rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :diagnosedDisease ;
          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasTreatmentType ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasMedication ;
          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasActiveIngredient ;
          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Tratamientos veterinarios porcinos"@es , "Veterinary Treatments"@en ;
    rdfs:comment "Conjunto de intervenciones médicas, preventivas y terapéuticas aplicadas a los cerdos con el objetivo de prevenir, controlar o curar enfermedades."@es ;
    dct:subject :DP0002 .

:Vaccination rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasVaccine ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :preventsDisease ;
          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Vacunaciones porcinas"@es , "Vaccinations"@en ;
    rdfs:comment "Conjunto de acciones preventivas mediante la administración de vacunas a los cerdos para protegerlos frente a enfermedades infecciosas."@es ;
    dct:subject :DP0002 .

:AnimalLoss rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :mortalityCause ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:string
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Bajas porcinas"@es , "Animal Losses"@en ;
    rdfs:comment "Registro de los animales que salen del sistema productivo debido a muerte, sacrificio sanitario o eliminación."@es ;
    dct:subject :DP0002 .


#################################################################
# FEEDING DOMAIN - DP0003
#################################################################

:FeedEntry rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :feedQuantity ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onDataRange xsd:decimal
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :feedType ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Entradas de pienso porcino"@es , "Feed Entries"@en ;
    rdfs:comment "Registro de los ingresos o recepciones de alimento en la explotación porcina."@es ;
    dct:subject :DP0003 .

:FeedingPhase rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :feedingPhaseFeedType ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Fases de alimentación porcino"@es , "Feeding Phases"@en ;
    rdfs:comment "Conjunto de etapas nutricionales en las que se divide la alimentación de los cerdos según su edad, peso y estado fisiológico."@es ;
    dct:subject :DP0003 .

:FeedFormula rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasIngredient ;
          owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasAminoAcid ;
          owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasMineral ;
          owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasVitamin ;
          owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Fórmulas de pienso porcino"@es , "Feed Formulas"@en ;
    rdfs:comment "Combinaciones específicas de ingredientes y nutrientes diseñadas para elaborar el alimento de los cerdos."@es ;
    dct:subject :DP0003 .

:FeedConversion rdf:type owl:Class ;
    rdfs:subClassOf
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasProductionStage ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :usesFeedFormula ;
          owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ,
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasGeneticLine ;
          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
          owl:onClass skos:Concept
        ] ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Conversión teórica porcina"@es , "Theoretical Feed Conversion"@en ;
    rdfs:comment "Indicador productivo que estima la cantidad de alimento necesaria para ganar una unidad de peso vivo."@es ;
    dct:subject :DP0003 .


#################################################################
#################################################################
##                                                             ##
##  LAYER 3 - PROPERTIES MODEL                                 ##
##                                                             ##
##  Hierarchical properties (subPropertyOf) with skos:notation ##
##  AP0001..AP0147 = stable opaque identifiers                 ##
##                                                             ##
#################################################################
#################################################################

#################################################################
# COMMON IDENTIFIERS
#################################################################

:identifier rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "identifier"@en , "identificador"@es ;
    rdfs:comment "Identificador único de una entidad."@es .

:animalIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :identifier ;
    rdfs:domain :Animal ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Identificador de animal"@es ;
    skos:notation "AP0001" .

:batchIdentifier rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :identifier ;
    rdfs:domain :Batch ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Identificador de lote"@es ;
    skos:notation "AP0008" .

#################################################################
# DATES
#################################################################

:hasDate rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "has date"@en , "tiene fecha"@es .

:birthDate rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasDate ;
    rdfs:domain :Animal ;
    rdfs:range xsd:date ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Fecha de nacimiento"@es ;
    skos:notation "AP0002" .

:batchEntryDate rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasDate ;
    rdfs:domain :Batch ;
    rdfs:range xsd:date ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Fecha de entrada del lote"@es ;
    skos:notation "AP0010" .

:slaughterDate rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasDate ;
    rdfs:domain :Batch ;
    rdfs:range xsd:date ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Fecha de sacrificio"@es ;
    skos:notation "AP0011" .

#################################################################
# NUMERIC PROPERTIES
#################################################################

:hasNumericValue rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "has numeric value"@en .

:animalAge rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasNumericValue ;
    rdfs:domain :Animal ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Edad del animal"@es ;
    skos:notation "AP0006" .

:animalWeight rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasNumericValue ;
    rdfs:domain :Animal ;
    rdfs:range xsd:decimal ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Peso del animal"@es .

:numberOfAnimals rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasNumericValue ;
    rdfs:domain :Batch ;
    rdfs:range xsd:integer ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
    rdfs:label "Número de animales"@es ;
    skos:notation "AP0013" .

:totalWeight rdf:type owl:DatatypeProperty ;
    rdfs:subPropertyOf :hasNumericValue ;
    rdfs:domain :Batch ;
    rdfs:range xsd:decimal ;
    rdfs:isDefinedBy <https://espordata.es/ontology/> ;
