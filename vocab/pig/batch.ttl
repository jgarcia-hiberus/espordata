@prefix pig:  <https://github.com/jgarcia-hiberus/espordata/blob/main/vocab/pig/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix s4agri: <https://saref.etsi.org/saref4agri/> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix cc:   <http://creativecommons.org/ns#> .

# ========================================
# ONTOLOGY METADATA
# ========================================

<https://espordata.eu/vocab/pig> a owl:Ontology ;
    dct:title "ESPORDATA Pig Batch Ontology"@en ;
    dct:title "Ontología ESPORDATA de Lotes Porcinos"@es ;
    dct:description "Vocabulary describing pig batches (homogeneous groups of animals sharing a production cycle) in the context of the ESPORDATA data space for the Spanish porcine sector."@en ;
    dct:description "Vocabulario que describe lotes porcinos (grupos homogéneos de animales que comparten ciclo productivo) en el contexto del data space ESPORDATA para el sector porcino español."@es ;
    dct:creator [ foaf:name "Jose Manuel Garcia de la Cuadra Nacher"; foaf:mbox <mailto:jgarciad@hiberus.com> ] ;
    dct:publisher [ foaf:name "Hiberus" ; foaf:homepage <https://www.hiberus.com/> ] ;
    dct:created "2025-11-01"^^xsd:date ;
    dct:modified "2026-04-22"^^xsd:date ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo "1.0.0" ;
    owl:versionIRI <https://github.com/jgarcia-hiberus/espordata/tree/main/vocab/pig> ;
    vann:preferredNamespaceUri "https://github.com/jgarcia-hiberus/espordata/tree/main/vocab/pig" ;
    vann:preferredNamespacePrefix "pig" ;
    rdfs:seeAlso <https://espordata.eu/> .

# ========================================
# LOTES (BATCHES)
# ========================================

pig:Batch a owl:Class ;
    rdfs:label "Lote de animales"@es ;
    rdfs:label "Animal batch"@en ;
    rdfs:subClassOf s4agri:LivestockGroup ;
    rdfs:comment "Grupo homogéneo de animales que comparten ciclo productivo."@es .

pig:batchId a owl:DatatypeProperty ;
    rdfs:label "Identificador de lote"@es ;
    rdfs:label "Batch identifier"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range xsd:string ;
    rdfs:comment "Identificador único global del lote."@es .

pig:birthDate a owl:DatatypeProperty ;
    rdfs:label "Fecha de nacimiento"@es ;
    rdfs:label "Birth date"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range xsd:date ;
    rdfs:comment "Fecha de nacimiento promedio o fecha de entrada a primera nave."@es .

pig:entryDate a owl:DatatypeProperty ;
    rdfs:label "Fecha de entrada"@es ;
    rdfs:label "Entry date"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range xsd:date ;
    rdfs:comment "Fecha entrada al ciclo/nave."@es .

pig:slaughterDate a owl:DatatypeProperty ;
    rdfs:label "Fecha de sacrificio"@es ;
    rdfs:label "Slaughter date"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range xsd:date ;
    rdfs:comment "Fecha de sacrificio del lote."@es .

pig:breed a owl:ObjectProperty ;
    rdfs:label "Raza o línea genética"@es ;
    rdfs:label "Breed or genetic line"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range skos:Concept ;
    rdfs:comment "Raza principal del lote. Referencia a pig:BreedScheme."@es .

pig:numberOfAnimalsIn a owl:DatatypeProperty ;
    rdfs:label "Número de animales entrada"@es ;
    rdfs:label "Number of animals in"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range xsd:integer .

pig:farm a owl:ObjectProperty ;
    rdfs:label "Explotación del lote"@es ;
    rdfs:label "Farm of batch"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range pig:Farm .

pig:totalWeight a owl:DatatypeProperty ;
    rdfs:label "Peso total"@es ;
    rdfs:label "Total weight"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Peso total del lote (kg)."@es .

pig:averageWeight a owl:DatatypeProperty ;
    rdfs:label "Peso medio"@es ;
    rdfs:label "Average weight"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range xsd:decimal ;
    rdfs:comment "Peso medio (kg)."@es .

pig:documentation a owl:DatatypeProperty ;
    rdfs:label "Documentación"@es ;
    rdfs:label "Documentation"@en ;
    rdfs:domain pig:Batch ;
    rdfs:range xsd:anyURI ;
    rdfs:comment "Referencia a documentos (PDF, etc.)."@es .