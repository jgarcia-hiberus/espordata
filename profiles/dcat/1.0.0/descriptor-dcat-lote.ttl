@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix esp:   <https://espordata.eu/datasets/> .

esp:pigbatch-dataset-001 a dcat:Dataset ;

    # ── OBLIGATORIOS ─────────────────────────────────────

    dct:title        "Lotes de Cerdos - Cooperativa Ibérica Sur"@es ;
    dct:description  "Lotes de cerdos para movimiento y trazabilidad de la Cooperativa Ibérica Sur, actualizados diariamente desde SITRAN."@es ;

    # ── RECOMENDADOS ─────────────────────────────────────

    dcat:contactPoint [ a vcard:Organization ;
        vcard:fn       "Dpto. de Datos - Coop. Ibérica Sur" ;
        vcard:hasEmail <mailto:datos@coop-iberica-sur.es> ] ;

    dcat:distribution esp:pigbatch-dist-api , esp:pigbatch-dist-csv ;

    dct:publisher [ a foaf:Organization ;
        foaf:name     "Cooperativa Ibérica Sur" ;
        foaf:homepage <https://www.coop-iberica-sur.es> ] ;

    dct:spatial   <https://sws.geonames.org/2510769/> ;

    dct:temporal [ a dct:PeriodOfTime ;
        dcat:startDate "2022-01-01"^^xsd:date ;
        dcat:endDate   "2024-12-31"^^xsd:date ] ;

    dcat:theme    <http://publications.europa.eu/resource/authority/data-theme/AGRI> ;

    # ── OPCIONALES ───────────────────────────────────────

    dct:modified  "2024-11-01"^^xsd:date ;
    dct:identifier "urn:espordata:pigbatch:coop-iberica-sur:2024" ;
    dct:accrualPeriodicity
        <http://publications.europa.eu/resource/authority/frequency/DAILY> ;

    dcat:keyword  "lote"@es , "porcino"@es , "trazabilidad"@es , "SITRAN"@es ;
    dct:created   "2024-01-15"^^xsd:date .


esp:pigbatch-dist-api a dcat:Distribution ;
    dct:title      "API REST - Lotes de Cerdos"@es ;
    dcat:mediaType <https://www.iana.org/assignments/media-types/application/json> ;
    dcat:accessURL <https://api.coop-iberica-sur.es/v1/pig-batches> ;
    dct:format     <http://publications.europa.eu/resource/authority/file-type/JSON> .

esp:pigbatch-dist-csv a dcat:Distribution ;
    dct:title        "Descarga CSV mensual"@es ;
    dcat:mediaType   <https://www.iana.org/assignments/media-types/text/csv> ;
    dcat:downloadURL <https://api.coop-iberica-sur.es/exports/pigbatch-monthly.csv> ;
    dct:format       <http://publications.europa.eu/resource/authority/file-type/CSV> .