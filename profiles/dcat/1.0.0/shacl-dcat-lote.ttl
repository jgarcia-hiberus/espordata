@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix pig:   <https://example-pork.eu/ontology#> .
@prefix porks: <https://pork-dataspace.eu/profiles/dcat/1.0.0/shacl#> .

# ─────────────────────────────────────────────────────────
#  VALIDADOR SHACL — Perfil DCAT Lote de Cerdos
#  Implementa: https://pork-dataspace.eu/profiles/dcat/1.0.0
#  Ejecutar con pySHACL contra el descriptor-dcat-lote.ttl
# ─────────────────────────────────────────────────────────

porks:DatasetShape
    a sh:NodeShape ;
    sh:targetClass dcat:Dataset ;
    sh:name        "Validador descriptor DCAT — lote porcino"@es ;

    # ── OBLIGATORIOS ──────────────────────────────────────

    sh:property [
        sh:path       dct:title ;
        sh:minCount   1 ;
        sh:datatype   rdf:langString ;
        sh:languageIn ("es") ;
        sh:severity   sh:Violation ;
        sh:message    "El dataset debe tener dct:title en español."@es ;
    ] ;

    sh:property [
        sh:path       dct:description ;
        sh:minCount   1 ;
        sh:datatype   rdf:langString ;
        sh:languageIn ("es") ;
        sh:severity   sh:Violation ;
        sh:message    "El dataset debe tener dct:description en español."@es ;
    ] ;

    sh:property [
        sh:path     dct:identifier ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:pattern  "^urn:pork-ds:[a-z0-9\\-]+:[a-z0-9\\-]+:[0-9]{4}$" ;
        sh:severity sh:Violation ;
        sh:message  "dct:identifier debe seguir el patrón urn:pork-ds:<tipo>:<org>:<año>."@es ;
    ] ;

    sh:property [
        sh:path     dct:subject ;
        sh:minCount 1 ;
        sh:hasValue pig:PigBatch ;
        sh:severity sh:Violation ;
        sh:message  "dct:subject debe referenciar pig:PigBatch."@es ;
    ] ;

    sh:property [
        sh:path     dct:conformsTo ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:pattern  "^https://pork-dataspace\\.eu/models/PigBatch/[0-9]+\\.[0-9]+\\.[0-9]+$" ;
        sh:severity sh:Violation ;
        sh:message  "dct:conformsTo debe apuntar a una versión semver del modelo PigBatch."@es ;
    ] ;

    sh:property [
        sh:path     dcat:theme ;
        sh:minCount 1 ;
        sh:hasValue <http://publications.europa.eu/resource/authority/data-theme/AGRI> ;
        sh:severity sh:Violation ;
        sh:message  "dcat:theme debe incluir el código AGRI del vocabulario EU."@es ;
    ] ;

    sh:property [
        sh:path     dct:publisher ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:node     porks:PublisherShape ;
        sh:severity sh:Violation ;
        sh:message  "El dataset debe tener exactamente un dct:publisher válido."@es ;
    ] ;

    sh:property [
        sh:path     dct:license ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Violation ;
        sh:message  "dct:license debe estar presente y ser una IRI."@es ;
    ] ;

    sh:property [
        sh:path     dct:accessRights ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:in (
            <http://publications.europa.eu/resource/authority/access-right/PUBLIC>
            <http://publications.europa.eu/resource/authority/access-right/RESTRICTED>
            <http://publications.europa.eu/resource/authority/access-right/NON_PUBLIC>
        ) ;
        sh:severity sh:Violation ;
        sh:message  "dct:accessRights debe usar el vocabulario EU Access Right."@es ;
    ] ;

    sh:property [
        sh:path     dcat:distribution ;
        sh:minCount 1 ;
        sh:node     porks:DistributionShape ;
        sh:severity sh:Violation ;
        sh:message  "El dataset debe tener al menos una dcat:distribution válida."@es ;
    ] ;

    # ── RECOMENDADOS ──────────────────────────────────────

    sh:property [
        sh:path     dct:temporal ;
        sh:node     porks:TemporalShape ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dct:temporal con dcat:PeriodOfTime."@es ;
    ] ;

    sh:property [
        sh:path     dct:accrualPeriodicity ;
        sh:nodeKind sh:IRI ;
        sh:pattern  "^http://publications\\.europa\\.eu/resource/authority/frequency/" ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda dct:accrualPeriodicity con vocabulario EU Frequency."@es ;
    ] ;

    sh:property [
        sh:path     dct:spatial ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dct:spatial."@es ;
    ] ;

    sh:property [
        sh:path     dcat:contactPoint ;
        sh:node     porks:ContactShape ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dcat:contactPoint."@es ;
    ] ;

    # ── OPCIONALES ────────────────────────────────────────

    sh:property [
        sh:path     dcat:keyword ;
        sh:datatype rdf:langString ;
    ] ;

    sh:property [
        sh:path     dct:created ;
        sh:datatype xsd:date ;
    ] ;

    sh:property [
        sh:path     dct:modified ;
        sh:datatype xsd:date ;
    ] .

# ─────────────────────────────────────────────────────────
#  Shapes auxiliares
# ─────────────────────────────────────────────────────────

porks:PublisherShape a sh:NodeShape ;
    sh:property [
        sh:path     foaf:name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Violation ;
        sh:message  "El publisher debe tener foaf:name."@es ;
    ] ;
    sh:property [
        sh:path     foaf:homepage ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda foaf:homepage en el publisher."@es ;
    ] .

porks:ContactShape a sh:NodeShape ;
    sh:property [
        sh:path     vcard:fn ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:severity sh:Violation ;
        sh:message  "El contacto debe tener vcard:fn."@es ;
    ] ;
    sh:property [
        sh:path     vcard:hasEmail ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message  "El contacto debe tener vcard:hasEmail."@es ;
    ] .

porks:TemporalShape a sh:NodeShape ;
    sh:property [
        sh:path     dcat:startDate ;
        sh:minCount 1 ;
        sh:datatype xsd:date ;
        sh:severity sh:Violation ;
        sh:message  "dcat:PeriodOfTime debe tener dcat:startDate."@es ;
    ] ;
    sh:property [
        sh:path     dcat:endDate ;
        sh:datatype xsd:date ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dcat:endDate."@es ;
    ] .

porks:DistributionShape a sh:NodeShape ;
    sh:targetClass dcat:Distribution ;

    sh:property [
        sh:path     dct:title ;
        sh:minCount 1 ;
        sh:datatype rdf:langString ;
        sh:severity sh:Violation ;
        sh:message  "La distribución debe tener dct:title."@es ;
    ] ;

    sh:property [
        sh:path     dcat:mediaType ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:in (
            <https://www.iana.org/assignments/media-types/application/json>
            <https://www.iana.org/assignments/media-types/text/csv>
            <https://www.iana.org/assignments/media-types/application/ld+json>
        ) ;
        sh:severity sh:Violation ;
        sh:message  "dcat:mediaType debe ser un IRI IANA: application/json, text/csv o application/ld+json."@es ;
    ] ;

    sh:or (
        [ sh:property [ sh:path dcat:accessURL  ; sh:minCount 1 ; sh:nodeKind sh:IRI ] ]
        [ sh:property [ sh:path dcat:downloadURL ; sh:minCount 1 ; sh:nodeKind sh:IRI ] ]
    ) ;

    sh:property [
        sh:path     dct:conformsTo ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:pattern  "^https://pork-dataspace\\.eu/models/PigBatch/[0-9]+\\.[0-9]+\\.[0-9]+$" ;
        sh:severity sh:Violation ;
        sh:message  "La distribución debe declarar dct:conformsTo apuntando al modelo PigBatch versionado."@es ;
    ] ;

    sh:property [
        sh:path     dct:format ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dct:format en la distribución."@es ;
    ] .