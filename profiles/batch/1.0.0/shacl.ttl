@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix pig:   <https://espordata.eu/vocab/pig#> .
@prefix esps:  <https://espordata.eu/profiles/dcat/1.0.0/shacl#> .

# ─────────────────────────────────────────────────────────
#  VALIDADOR SHACL — Perfil DCAT Lote de Cerdos (ESPORDATA)
#  Implementa: https://espordata.eu/profiles/dcat/1.0.0
#  Ejecutar con pySHACL contra el descriptor-dcat-lote.ttl
# ─────────────────────────────────────────────────────────

esps:DatasetShape
    a sh:NodeShape ;
    sh:targetClass dcat:Dataset ;
    sh:name        "Validador descriptor DCAT — lote porcino"@es ;

    # ── OBLIGATORIOS ──────────────────────────────────────

    sh:property [
        sh:path      dct:title ;
        sh:minCount  1 ;
        sh:nodeKind  sh:Literal ;
        sh:severity  sh:Violation ;
        sh:message   "El dataset debe tener al menos un dct:title."@es ;
    ] ;

    sh:property [
        sh:path      dct:description ;
        sh:minCount  1 ;
        sh:nodeKind  sh:Literal ;
        sh:severity  sh:Violation ;
        sh:message   "El dataset debe tener al menos un dct:description."@es ;
    ] ;

    # ── RECOMENDADOS ──────────────────────────────────────

    sh:property [
        sh:path     dcat:contactPoint ;
        sh:node     esps:ContactShape ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dcat:contactPoint."@es ;
    ] ;

    sh:property [
        sh:path     dcat:distribution ;
        sh:node     esps:DistributionShape ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar al menos una dcat:distribution."@es ;
    ] ;

    sh:property [
        sh:path     dct:publisher ;
        sh:maxCount 1 ;
        sh:node     esps:PublisherShape ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dct:publisher (máximo 1)."@es ;
    ] ;

    sh:property [
        sh:path     dct:spatial ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dct:spatial."@es ;
    ] ;

    sh:property [
        sh:path     dct:temporal ;
        sh:node     esps:TemporalShape ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dct:temporal con dct:PeriodOfTime."@es ;
    ] ;

    sh:property [
        sh:path     dcat:theme ;
        sh:class    skos:Concept ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dcat:theme con un skos:Concept."@es ;
    ] ;

    # ── OPCIONALES ────────────────────────────────────────

    sh:property [
        sh:path     dct:modified ;
        sh:or (
            [ sh:datatype xsd:date ]
            [ sh:datatype xsd:dateTime ]
        ) ;
        sh:maxCount 1 ;
        sh:severity sh:Info ;
        sh:message  "dct:modified debe ser xsd:date o xsd:dateTime."@es ;
    ] ;

    sh:property [
        sh:path     dct:identifier ;
        sh:nodeKind sh:Literal ;
        sh:severity sh:Info ;
        sh:message  "dct:identifier debe ser un literal."@es ;
    ] ;

    sh:property [
        sh:path     dct:accrualPeriodicity ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
        sh:severity sh:Info ;
        sh:message  "dct:accrualPeriodicity debe ser una IRI de dct:Frequency."@es ;
    ] .

# ─────────────────────────────────────────────────────────
#  Shapes auxiliares
# ─────────────────────────────────────────────────────────

esps:PublisherShape a sh:NodeShape ;
    sh:property [
        sh:path     foaf:name ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:severity sh:Violation ;
        sh:message  "El publisher debe tener foaf:name."@es ;
    ] ;
    sh:property [
        sh:path     foaf:homepage ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda foaf:homepage en el publisher."@es ;
    ] .

esps:ContactShape a sh:NodeShape ;
    sh:property [
        sh:path     vcard:fn ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:severity sh:Violation ;
        sh:message  "El contacto debe tener vcard:fn."@es ;
    ] ;
    sh:property [
        sh:path     vcard:hasEmail ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message  "El contacto debe tener vcard:hasEmail."@es ;
    ] .

esps:TemporalShape a sh:NodeShape ;
    sh:property [
        sh:path     dcat:startDate ;
        sh:minCount 1 ;
        sh:datatype xsd:date ;
        sh:severity sh:Violation ;
        sh:message  "dct:PeriodOfTime debe tener dcat:startDate."@es ;
    ] ;
    sh:property [
        sh:path     dcat:endDate ;
        sh:datatype xsd:date ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dcat:endDate."@es ;
    ] .

esps:DistributionShape a sh:NodeShape ;
    sh:property [
        sh:path     dct:title ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:severity sh:Violation ;
        sh:message  "La distribución debe tener dct:title."@es ;
    ] ;
    sh:property [
        sh:path     dcat:mediaType ;
        sh:nodeKind sh:IRI ;
        sh:severity sh:Warning ;
        sh:message  "Se recomienda declarar dcat:mediaType como IRI IANA."@es ;
    ] ;
    sh:or (
        [ sh:property [ sh:path dcat:accessURL  ; sh:minCount 1 ; sh:nodeKind sh:IRI ] ]
        [ sh:property [ sh:path dcat:downloadURL ; sh:minCount 1 ; sh:nodeKind sh:IRI ] ]
    ) .