@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix dcat:  <http://www.w3.org/ns/dcat#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix prof:  <http://www.w3.org/ns/dx/prof/> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix adms:  <http://www.w3.org/ns/adms#> .
@prefix pig:   <https://espordata.eu/vocab/pig#> .
@prefix esp:   <https://espordata.eu/profiles/dcat/> .

# ─────────────────────────────────────────────────────────
#  PERFIL DCAT — Lote de Cerdos (ESPORDATA)
#  URI canónica: https://espordata.eu/profiles/dcat/1.0.0
#  Este documento describe QUÉ debe contener un descriptor
#  DCAT para datasets de tipo pig:Batch.
#  NO es ejecutable — es la especificación normativa.
# ─────────────────────────────────────────────────────────

esp:1.0.0
    a                    dcat:DatasetSeries, prof:Profile ;
    rdfs:label           "Perfil DCAT — Lote de Cerdos"@es ;
    rdfs:comment         """
        Perfil DCAT obligatorio para publicar datasets de tipo pig:Batch
        en ESPORDATA. Basado en DCAT-AP 2.1.
        Todo descriptor que no cumpla este perfil será rechazado por el catálogo.
    """@es ;
    owl:versionInfo      "1.0.0" ;
    dct:issued           "2025-01-01"^^xsd:date ;
    dct:publisher        <https://espordata.eu/governance> ;
    dct:isProfileOf      <https://www.w3.org/TR/vocab-dcat-2/> .

# ─────────────────────────────────────────────────────────
#  Propiedades OBLIGATORIAS para dcat:Dataset
# ─────────────────────────────────────────────────────────

esp:title a rdf:Property ;
    rdfs:label          "Título"@es ;
    rdfs:comment        """
        dct:title. Título del Dataset.
        Rango: rdfs:Literal. Cardinalidad: 1..n.
    """@es ;
    rdfs:domain         dcat:Dataset ;
    rdfs:range          rdfs:Literal ;
    owl:minCardinality  1 .

esp:description a rdf:Property ;
    rdfs:label          "Descripción"@es ;
    rdfs:comment        """
        dct:description. Descripción libre del Dataset.
        Rango: rdfs:Literal. Cardinalidad: 1..n.
    """@es ;
    rdfs:domain         dcat:Dataset ;
    rdfs:range          rdfs:Literal ;
    owl:minCardinality  1 .

# ─────────────────────────────────────────────────────────
#  Propiedades RECOMENDADAS para dcat:Dataset
# ─────────────────────────────────────────────────────────

esp:contactPoint a rdf:Property ;
    rdfs:label      "Punto de contacto"@es ;
    rdfs:comment    """
        dcat:contactPoint. Información de contacto para enviar comentarios
        sobre el dataset.
        Rango: vcard:Kind. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      vcard:Kind .

esp:distribution a rdf:Property ;
    rdfs:label      "Distribución del dataset"@es ;
    rdfs:comment    """
        dcat:distribution. Distribución disponible del dataset
        (csv, json, ttl, etc.).
        Rango: dcat:Distribution. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      dcat:Distribution .

esp:keyword a rdf:Property ;
    rdfs:label      "Palabra clave"@es ;
    rdfs:comment    """
        dcat:keyword. Palabra o etiqueta que describe el dataset, útil
        para indexación y búsqueda en el catálogo.
        Rango: rdfs:Literal. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      rdfs:Literal .

esp:publisher a rdf:Property ;
    rdfs:label      "Publisher"@es ;
    rdfs:comment    """
        dct:publisher. Entidad responsable de disponibilizar el dataset.
        Rango: foaf:Agent. Cardinalidad: 0..1.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      foaf:Agent ;
    owl:maxCardinality 1 .

esp:spatial a rdf:Property ;
    rdfs:label      "Cobertura geográfica"@es ;
    rdfs:comment    """
        dct:spatial. Región geográfica que cubre el dataset.
        Rango: dct:Location. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      dct:Location .

esp:temporal a rdf:Property ;
    rdfs:label      "Cobertura temporal"@es ;
    rdfs:comment    """
        dct:temporal. Periodo temporal que cubre el dataset.
        Rango: dct:PeriodOfTime. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      dct:PeriodOfTime .

esp:theme a rdf:Property ;
    rdfs:label      "Tema o categoría"@es ;
    rdfs:comment    """
        dcat:theme (subpropiedad de dct:subject). Tema o categoría del dataset,
        idealmente tomado de un vocabulario controlado (p. ej. EU data themes).
        Rango: skos:Concept. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      skos:Concept .

esp:status a rdf:Property ;
    rdfs:label      "Estado del activo"@es ;
    rdfs:comment    """
        adms:status. Estado de madurez/ciclo de vida del dataset
        (activo, retirado, en revisión, etc.). Se recomienda usar la lista
        controlada ADMS Status (http://purl.org/adms/status/):
          - Completed        → activo / publicado
          - UnderDevelopment → en revisión / en desarrollo
          - Deprecated       → obsoleto pero accesible
          - Withdrawn        → retirado
        Rango: skos:Concept. Cardinalidad: 0..1.

        Nota de divergencia respecto a DCAT-AP: en DCAT-AP estándar,
        adms:status se aplica solo a dcat:Distribution. ESPORDATA la extiende
        a dcat:Dataset porque el ciclo de vida del lote conceptual es
        información clave para los consumidores del data space. Esta
        extensión es semánticamente válida (ADMS no declara rdfs:domain
        sobre adms:status) y sigue precedentes de otros perfiles
        sectoriales DCAT-AP nacionales.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      skos:Concept ;
    owl:maxCardinality 1 .

# ─────────────────────────────────────────────────────────
#  Propiedades OPCIONALES para dcat:Dataset
# ─────────────────────────────────────────────────────────

esp:creator a rdf:Property ;
    rdfs:label      "Creador"@es ;
    rdfs:comment    """
        dct:creator. Entidad responsable de la creación del dataset.
        A diferencia de dct:publisher, identifica al autor original
        de los datos, no a quien los disponibiliza.
        Rango: foaf:Agent. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      foaf:Agent .

esp:identifier a rdf:Property ;
    rdfs:label      "Identificador"@es ;
    rdfs:comment    """
        dct:identifier. Identificador para el dataset: URI u otro identificador
        único en el contexto del catálogo.
        Rango: rdfs:Literal. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      rdfs:Literal .

esp:accrualPeriodicity a rdf:Property ;
    rdfs:label      "Frecuencia de actualización"@es ;
    rdfs:comment    """
        dct:accrualPeriodicity. Frecuencia con la que se actualiza el dataset.
        Rango: dct:Frequency. Cardinalidad: 0..1.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      dct:Frequency ;
    owl:maxCardinality 1 .

esp:language a rdf:Property ;
    rdfs:label      "Idioma"@es ;
    rdfs:comment    """
        dct:language. Idioma o idiomas del dataset. Se recomienda usar
        códigos del Authority Table 'Languages NAL' del Publications Office UE
        (p. ej. http://publications.europa.eu/resource/authority/language/SPA).
        Rango: dct:LinguisticSystem. Cardinalidad: 0..n.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      dct:LinguisticSystem .

esp:modified a rdf:Property ;
    rdfs:label      "Fecha de modificación"@es ;
    rdfs:comment    """
        dct:modified. Fecha más reciente en que el dataset ha sido
        cambiado o modificado.
        Rango: xsd:date o xsd:dateTime. Cardinalidad: 0..1.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      [ owl:unionOf ( xsd:date xsd:dateTime ) ] ;
    owl:maxCardinality 1 .

esp:versionInfo a rdf:Property ;
    rdfs:label      "Información de versión"@es ;
    rdfs:comment    """
        owl:versionInfo. Identificador de versión del dataset
        (p. ej. '1.0.0', '2025-Q1'). Es metadato textual de versión,
        no un enlace a otra versión (eso es dct:hasVersion).
        Rango: rdfs:Literal. Cardinalidad: 0..1.
    """@es ;
    rdfs:domain     dcat:Dataset ;
    rdfs:range      rdfs:Literal ;
    owl:maxCardinality 1 .
